{
  "name": "ufsc-dso2-trabalho1-mercadozetta",
  "private": true,
  "engines": {
    "node": ">=24.18.0"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "npm run dev:backend & npm run dev:frontend",
    "dev:local": "npm run db:up && npm run dev",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "db:up": "docker compose up -d mongo",
    "db:down": "docker compose stop mongo",
    "db:logs": "docker logs -f mercadozetta-mongo",
    "seed:demo": "npm --prefix backend run seed:demo",
    "generate:openapi": "npm --prefix backend run generate:openapi",
    "compose:up": "docker compose up --build",
    "compose:seed": "docker compose run --rm backend npm run seed:demo",
    "compose:down": "docker compose down",
    "typecheck": "npm --prefix backend run compile",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "npm --prefix backend run lint",
    "lint:frontend": "npm --prefix frontend run lint",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "npm run typecheck && npm run test:backend && npm run test:frontend",
    "test:integration": "bash scripts/test-integration.sh",
    "test:coverage": "npm run test:coverage:backend && npm run test:coverage:frontend",
    "test:backend": "npm --prefix backend test",
    "test:frontend": "npm --prefix frontend test",
    "test:coverage:backend": "npm --prefix backend run test:coverage",
    "test:coverage:frontend": "npm --prefix frontend run test:coverage"
  },
  "devDependencies": {
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md,html,yml,yaml}": "prettier --write"
  }
}
