{
  "name": "backend",
  "version": "1.0.0",
  "main": "src/server.ts",
  "license": "MIT",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "generate:openapi": "ts-node src/scripts/generateOpenApi.ts",
